generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(member)
  avatar    String   @default("?")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  sales         Sale[]         @relation("SellerSales")
  tasks         Task[]         @relation("AssigneeTasks")
  logs          Log[]
  stockEntries  StockHistory[]
  projects      ProjectMember[]
  events        Event[]

  @@map("users")
}

enum Role {
  admin
  member
  viewer
  finance
}

model Product {
  id             Int            @id @default(autoincrement())
  name           String
  description    String         @default("")
  price          Float          // TTC
  priceHT        Float
  sku            String         @default("")
  category       String         @default("")
  alertThreshold Int            @default(10)
  createdAt      DateTime       @default(now())

  // Relations
  stocks       UserStock[]
  stockHistory StockHistory[]
  sales        Sale[]

  @@map("products")
}

model UserStock {
  id        Int     @id @default(autoincrement())
  productId Int
  username  String
  quantity  Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, username])
  @@map("user_stocks")
}

model StockHistory {
  id          Int      @id @default(autoincrement())
  productId   Int
  date        DateTime @default(now())
  type        String   // entry, exit, sale, cancel
  quantity    Int
  stockBefore Int
  stockAfter  Int
  userId      Int?
  user        String
  reason      String   @default("")
  reference   String?

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userRef     User?    @relation(fields: [userId], references: [id])

  @@map("stock_history")
}

model Client {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @default("")
  phone       String   @default("")
  company     String   @default("")
  status      String   @default("one-shot") // recurrent, permanent, one-shot, inactive
  notes       String   @default("")
  createdAt   DateTime @default(now())

  // Relations
  sales       Sale[]

  @@map("clients")
}

model Sale {
  id           Int      @id @default(autoincrement())
  productId    Int
  clientId     Int?
  sellerId     Int
  quantity     Int
  unitPriceTTC Float
  unitPriceHT  Float
  totalTTC     Float
  totalHT      Float
  status       String   @default("completed") // completed, cancelled, postponed
  platform     String   @default("vente_locale")
  date         DateTime @default(now())
  createdAt    DateTime @default(now())

  // Relations
  product      Product  @relation(fields: [productId], references: [id])
  client       Client?  @relation(fields: [clientId], references: [id])
  seller       User     @relation("SellerSales", fields: [sellerId], references: [id])

  @@map("sales")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  dueDate     DateTime?
  status      String   @default("en_cours")
  completed   Boolean  @default(false)
  cancelled   Boolean  @default(false)
  priority    String   @default("medium") // high, medium, low
  assigneeId  Int?
  projectId   Int?
  createdAt   DateTime @default(now())

  // Relations
  assignee    User?    @relation("AssigneeTasks", fields: [assigneeId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
  comments    TaskComment[]

  @@map("tasks")
}

model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  userId    Int
  content   String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  status      String   @default("active") // active, paused, completed, cancelled
  priority    String   @default("medium")
  emoji       String   @default("📁")
  createdAt   DateTime @default(now())

  // Relations
  members     ProjectMember[]
  tasks       Task[]

  @@map("projects")
}

model ProjectMember {
  id        Int     @id @default(autoincrement())
  projectId Int
  userId    Int

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Log {
  id        Int      @id @default(autoincrement())
  action    String
  details   String   @default("")
  userId    Int
  userName  String
  timestamp DateTime @default(now())
  module    String   @default("")

  user      User     @relation(fields: [userId], references: [id])

  @@map("logs")
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  date        DateTime
  endDate     DateTime?
  type        String   @default("reminder") // meeting, call_urgent, call, reminder, personal
  color       String   @default("#2e4a8a")
  userId      Int
  projectId   Int?
  allDay      Boolean  @default(true)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@map("events")
}
